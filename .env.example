# =============================================================================
# DEALERSHIP TEMPLATE — Environment Variables Template
# =============================================================================
# Copy this file and rename to .env
# Fill in all [PLACEHOLDER] values for your environment
# Never commit the actual .env file to version control
# =============================================================================

# ============================================================
# BACKEND / SPRING BOOT CONFIGURATION
# ============================================================

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/dealership_db
SPRING_DATASOURCE_USERNAME=dealership_user
SPRING_DATASOURCE_PASSWORD=[SECURE_DB_PASSWORD_HERE]
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQL10Dialect

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/
SPRING_APPLICATION_NAME=dealership-api

# JWT / Security
APP_JWT_SECRET=[MIN_32_CHARACTERS_SECURE_KEY_HERE_MIN_32_CHARACTERS]
APP_JWT_EXPIRATION=86400000

# Admin Credentials (change in production!)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=[STRONG_ADMIN_PASSWORD_HERE]

# CORS Configuration
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdealership.com,https://www.yourdealership.com

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_DEALERSHIP=DEBUG
LOGGING_FILE_NAME=logs/dealership-api.log
LOGGING_FILE_MAX_SIZE=10MB

# ============================================================
# FRONTEND / VUE CONFIGURATION
# ============================================================

# API Base URL (points to backend)
VITE_API_BASE_URL=http://localhost:8080
# Production:
# VITE_API_BASE_URL=https://your-backend-url.com

# Cloudinary Configuration (for image uploads)
VITE_CLOUDINARY_CLOUD_NAME=[YOUR_CLOUDINARY_CLOUD_NAME]
VITE_CLOUDINARY_UPLOAD_PRESET=[YOUR_CLOUDINARY_UPLOAD_PRESET]
VITE_CLOUDINARY_API_KEY=[OPTIONAL_CLOUDINARY_API_KEY]

# Environment
VITE_ENV=development
# Production:
# VITE_ENV=production

# ============================================================
# OPTIONAL: EMAIL CONFIGURATION (Contact Form)
# ============================================================

# SendGrid
SPRING_MAIL_HOST=smtp.sendgrid.net
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=apikey
SPRING_MAIL_PASSWORD=[SENDGRID_API_KEY_HERE]
SPRING_MAIL_FROM=noreply@yourdealership.com

# Alternative: AWS SES
# SPRING_MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=[AWS_SES_USERNAME]
# SPRING_MAIL_PASSWORD=[AWS_SES_PASSWORD]

# Alternative: Gmail
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-email@gmail.com
# SPRING_MAIL_PASSWORD=[GMAIL_APP_PASSWORD]

# ============================================================
# OPTIONAL: EXTERNAL SERVICE CREDENTIALS
# ============================================================

# Google Maps (for location embed)
VITE_GOOGLE_MAPS_API_KEY=[OPTIONAL_GOOGLE_MAPS_API_KEY]

# Google Analytics (tracking)
VITE_GOOGLE_ANALYTICS_ID=[OPTIONAL_GA_ID]

# Sentry (error tracking)
SENTRY_DSN=[OPTIONAL_SENTRY_DSN]

# ============================================================
# DEPLOYMENT SPECIFIC
# ============================================================

# Railway.app
# RAILWAY_ENVIRONMENT_NAME=production

# Heroku
# NODE_ENV=production
# NPM_CONFIG_PRODUCTION=true

# AWS
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=[AWS_KEY]
# AWS_SECRET_ACCESS_KEY=[AWS_SECRET]

# ============================================================
# DEVELOPMENT SPECIFIC
# ============================================================

# Debug mode (local development only)
DEBUG=false
# DEBUG=true  # Uncomment for verbose logging

# Hot reload
VITE_HMR=true

# ============================================================
# NOTES FOR SETUP
# ============================================================

# 1. DATABASE PASSWORD:
#    - Use at least 12 random characters
#    - Include uppercase, lowercase, numbers, symbols
#    - Example: Tr0pic@lSunset#2024$

# 2. JWT SECRET:
#    - Minimum 32 characters
#    - Use a secure random string generator
#    - Generate: openssl rand -base64 32

# 3. ADMIN PASSWORD:
#    - Change immediately after first login
#    - Use strong, unique password
#    - Store securely (password manager)

# 4. CLOUDINARY:
#    - Sign up at https://cloudinary.com
#    - Free tier: 25GB storage/month
#    - Get credentials from Cloudinary dashboard

# 5. API BASE URL:
#    - Local dev: http://localhost:8080
#    - Production: https://your-api-domain.com

# 6. CORS ORIGINS:
#    - List all domains that will access the API
#    - Include http:// and https:// versions
#    - Include www and non-www variants

# 7. EMAIL:
#    - If not using email, leave SendGrid vars empty
#    - Choose ONE email provider
#    - Verify domain before sending (SendGrid/SES)

# ============================================================
# LOADING ENVIRONMENT VARIABLES
# ============================================================

# Spring Boot automatically loads:
# 1. application.properties (default)
# 2. .env file (if spring-dotenv or similar is configured)
# 3. System environment variables (highest priority)

# Frontend (Vite) loads VITE_* variables:
# 1. .env file
# 2. .env.local (git-ignored)
# 3. Command line: npm run dev -- --mode production

# ============================================================
# GIT SAFETY
# ============================================================

# Add to .gitignore (NEVER commit .env files):
# .env
# .env.local
# .env.*.local
# *.pem
# *.key

# ============================================================
